{
  "name": "customervoice",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "start": "pnpm infra:up && pnpm dev",
    "stop": "pnpm infra:down",
    "dev": "pnpm run dev:stack",
    "dev:stack": "turbo run dev --parallel --filter=@customervoice/api --filter=@customervoice/web --filter=@customervoice/worker",
    "dev:all": "turbo run dev --parallel",
    "dev:api": "pnpm --filter @customervoice/api dev",
    "dev:web": "pnpm --filter @customervoice/web dev",
    "dev:worker": "pnpm --filter @customervoice/worker dev",
    "dev:mobile": "pnpm --filter @customervoice/mobile dev",
    "infra:up": "docker compose -f infra/docker/docker-compose.yml up -d postgres redis mailhog minio",
    "infra:down": "docker compose -f infra/docker/docker-compose.yml down",
    "infra:logs": "docker compose -f infra/docker/docker-compose.yml logs -f postgres redis mailhog minio",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:integration": "turbo run test:integration",
    "test:e2e": "turbo run test:e2e"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "eslint": "^9.17.0",
    "globals": "^17.3.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.56.1"
  }
}