{
  "name": "@customervoice/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "db:migrate": "tsx src/db/migrate-cli.ts",
    "lint": "eslint 'src/**/*.ts'",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests --exclude test/integration-db/**",
    "test:integration": "vitest run --passWithNoTests --dir test/integration",
    "test:integration:db": "vitest run --dir test/integration-db",
    "test:e2e": "echo 'api e2e tests not scaffolded yet'"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1003.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "express-session": "^1.19.0",
    "jose": "^5.9.6",
    "multer": "^2.1.1",
    "passport": "^0.7.0",
    "passport-saml": "^3.2.4",
    "pg": "^8.13.1",
    "uuid": "^11.0.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.2",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.10.2",
    "@types/passport": "^1.0.17",
    "@types/passport-saml": "^1.1.7",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.17.0",
    "supertest": "^7.1.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
